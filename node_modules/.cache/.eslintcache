 { id } = useParams();\r\n  const [item, setItem] = useState(\"\");\r\n  useEffect(() => {\r\n    getData();\r\n  }, []);\r\n\r\n  const getData = async () => {\r\n    const result = await axios.get(\r\n      \"https://5d76bf96515d1a0014085cf9.mockapi.io/product\"\r\n    );\r\n    setItem(result.data[id - 1]);\r\n  };\r\n\r\n const addItem =() => {\r\n    const new_contact = {\r\n      name: item.name,\r\n      preview: item.preview,\r\n      price: item.price,\r\n      id : new Date().getTime().toString(),\r\n    };\r\n    dispatch(addToCart(new_contact));\r\n    history.push(\"/\");\r\n  }\r\n\r\n  return (\r\n    <div className=\"container\">\r\n      <div className=\"left\">\r\n        <img className=\"mainImage\" src={item.preview} alt=\"\" />\r\n      </div>\r\n      <div className=\"right\">\r\n        <h1>{item.name}</h1>\r\n        <h4>{item.brand}</h4>\r\n        <h3>Price: Rs {item.price}</h3>\r\n        <h3>Description</h3>\r\n        <p>{item.description}</p>\r\n        <button onClick={addItem}>Add to Cart</button>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\nexport default Card;\r\n","C:\\Users\\win\\Desktop\\Desktop\\shop-lane\\src\\components\\home\\Home.js",[],"C:\\Users\\win\\Desktop\\Desktop\\shop-lane\\src\\actions\\actions.js",[],"C:\\Users\\win\\Desktop\\Desktop\\shop-lane\\src\\reducer\\reducer.js",[],"C:\\Users\\win\\Desktop\\Desktop\\shop-lane\\src\\components\\cart\\cart.js",[],"C:\\Users\\win\\Desktop\\Desktop\\shop-lane\\src\\components\\checkout\\checkout.js",[],{"ruleId":"51","replacedBy":"52"},{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","severity":1,"message":"56","line":16,"column":6,"nodeType":"57","endLine":16,"endColumn":8,"suggestions":"58"},"no-native-reassign",["59"],"no-negated-in-lhs",["60"],"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'getData'. Either include it or remove the dependency array.","ArrayExpression",["61"],"no-global-assign","no-unsafe-negation",{"desc":"62","fix":"63"},"U